# RFID Attendance System - Environment Variables
# Copy this file to .env and fill in your actual values

PORT=3000

# Turso Database — https://turso.tech (free tier)
# For local dev leave TURSO_DATABASE_URL=file:local.db and TURSO_AUTH_TOKEN empty
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-auth-token-here

# Twilio Credentials — Get from https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Daily absent notification time (24h format, IST)
NOTIFY_TIME=18:00

# Set to "false" to disable SMS (useful during testing)
SMS_ENABLED=true

# ─── Authentication Keys ──────────────────────────────────────────────────────
#
# DEVICE_KEY — Used by ESP32 hardware to authenticate scan requests.
#   → Share this with anyone setting up an ESP32 for your system (e.g. your friend).
#   → They paste it into the firmware (DEVICE_KEY constant in .ino file).
#   → Without this, no ESP32 can post scans.
#   → Use any strong random string, e.g.: openssl rand -hex 16
DEVICE_KEY=your-device-key-here

# ADMIN_KEY — Used by the web portal admin. Protects add/delete students & SMS.
#   → Only YOU should know this key. Enter it in the portal "Admin Login" prompt.
#   → Without this, the portal runs in view-only mode (can see data, not modify).
#   → Use a different strong random string from DEVICE_KEY.
ADMIN_KEY=your-admin-key-here
